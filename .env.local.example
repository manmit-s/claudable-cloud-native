# ============================================================
# Claudable - Environment Variables (Cloud-Native SaaS)
# Copy this file to `.env.local` and fill in real values.
# ============================================================

# ---- Supabase (Auth + Postgres + Storage) ----
# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Public anon key (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key (server-only! NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Database (Supabase Postgres via Prisma) ----
# Pooled connection (used by the app at runtime). Uses port 6543 + pgBouncer.
DATABASE_URL=postgresql://postgres:PASSWORD@db.XXXXXXXXXXXX.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1
# Direct connection (used by Prisma CLI for migrations). Uses port 5432.
DIRECT_URL=postgresql://postgres:PASSWORD@db.XXXXXXXXXXXX.supabase.co:5432/postgres

# ---- Orchestrator (EC2 backend, Phase 2+) ----
# Base URL of the Node.js orchestrator service, e.g. https://api.yourdomain.com
ORCHESTRATOR_URL=http://localhost:8080
# WebSocket URL for real-time streaming from the orchestrator
ORCHESTRATOR_WS_URL=ws://localhost:8080

# ---- Anthropic (Claude Code) ----
ANTHROPIC_API_KEY=your-anthropic-api-key

# ---- Existing / Local Dev ----
# Local projects directory (used until container workspaces are wired in Phase 2)
PROJECTS_DIR=./data/projects
